{
  "name": "makstech/montonio-php-sdk",
  "description": "Montonio PHP Library",
  "keywords": [
    "montonio",
    "payment",
    "payments"
  ],
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/makstech/montonio-php-sdk",
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "firebase/php-jwt": "^6.0 || ^7.0",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.1 || ^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "suggest": {
    "guzzlehttp/guzzle": "PSR-18 HTTP client implementation",
    "nyholm/psr7": "Lightweight PSR-7/PSR-17 implementation"
  },
  "autoload": {
    "psr-4": {
      "Montonio\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Max Slotov",
      "email": "max@slotov.dev"
    }
  ],
  "config": {
    "lock": false
  }
}
